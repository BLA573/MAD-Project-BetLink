<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_premium">

    <!-- Perfectly centered container for the brand identity -->
    <LinearLayout
        android:id="@+id/splashBrandBlock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.45">

        <!-- Sophisticated Logo Mark -->
        <TextView
            android:id="@+id/textBrandMark"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_splash_mark"
            android:elevation="4dp"
            android:gravity="center"
            android:letterSpacing="0.05"
            android:text="@string/splash_brand_mark"
            android:textColor="@color/brand_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <!-- Refined Wordmark -->
        <TextView
            android:id="@+id/textBrandWordmark"
            style="@style/TextAppearance.BetLink.SplashWordmark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/app_name"
            android:textColor="@color/text_primary" />

        <!-- Minimalist Tagline -->
        <TextView
            android:id="@+id/textTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:alpha="0.6"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.1"
            android:text="@string/brand_tagline"
            android:textAllCaps="true"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Premium, thin loading indicator -->
    <ProgressBar
        android:id="@+id/splashLoader"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="140dp"
        android:layout_height="3dp"
        android:layout_marginTop="48dp"
        android:indeterminate="true"
        android:indeterminateTint="@color/brand_primary"
        android:progressBackgroundTint="#101E40AF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/splashBrandBlock" />

</androidx.constraintlayout.widget.ConstraintLayout>
