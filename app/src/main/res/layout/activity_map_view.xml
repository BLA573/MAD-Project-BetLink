<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Map placeholder -->
    <View
        android:id="@+id/mapContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/surface" />

    <!-- Bottom preview card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        android:background="@drawable/card_bg"
        android:padding="24dp">

        <TextView
            android:id="@+id/previewTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/TextAppearance.BetLink.H2"
            android:text="Sample Place"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/previewSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/TextAppearance.BetLink.Body"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_secondary"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/buttonPreviewBook"
            style="@style/Widget.BetLink.Button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="@string/book_now"
            android:textColor="@color/white"
            android:backgroundTint="@color/brand_primary" />
    </LinearLayout>

</FrameLayout>
