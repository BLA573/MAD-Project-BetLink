<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base App Theme (Material Components) -->
    <style name="Theme.BetLink" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryVariant">@color/brand_primary_variant</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/brand_accent</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <item name="android:statusBarColor">@color/brand_primary_variant</item>
        <item name="android:navigationBarColor">@color/background</item>

        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>

        <!-- Material Component compatibility -->
        <item name="materialButtonStyle">@style/Widget.BetLink.Button</item>
        <item name="textInputStyle">@style/Widget.BetLink.TextInputLayout</item>
    </style>

    <!-- MainActivity Theme -->
    <style name="Theme.BetLink.Main" parent="Theme.BetLink">
        <item name="android:statusBarColor">#80000000</item>
        <item name="android:windowTranslucentStatus">true</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.BetLink.Splash" parent="Theme.BetLink">
        <item name="android:windowBackground">@drawable/bg_splash_premium</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <!-- Global Component Styles -->
    <style name="Widget.BetLink.Button" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:minHeight">56dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.BetLink.Button.Host" parent="Widget.BetLink.Button">
        <item name="backgroundTint">@color/host_primary</item>
    </style>

    <style name="Widget.BetLink.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:minHeight">56dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="strokeColor">@color/brand_primary</item>
        <item name="strokeWidth">2dp</item>
    </style>

    <style name="Widget.BetLink.Button.Outlined.Host" parent="Widget.BetLink.Button.Outlined">
        <item name="android:textColor">@color/text_primary</item>
        <item name="strokeColor">@color/host_primary</item>
    </style>

    <style name="Widget.BetLink.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/brand_primary</item>
        <item name="hintTextColor">@color/brand_primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <!-- Calendar Styles -->
    <style name="CalendarDayHeader">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingVertical">8dp</item>
    </style>

    <style name="CalendarDate">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">12dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:background">?attr/selectableItemBackground</item>
    </style>

    <style name="CalendarDate.Booked">
        <item name="android:background">@drawable/pill_bg</item>
        <item name="android:backgroundTint">@color/host_tint</item>
        <item name="android:textColor">@color/host_primary</item>
    </style>

    <style name="CalendarDate.Blocked">
        <item name="android:background">@drawable/pill_bg</item>
        <item name="android:backgroundTint">#FEE2E2</item>
        <item name="android:textColor">@color/danger</item>
    </style>

    <!-- Typography Styles -->
    <style name="TextAppearance.BetLink.H1" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.BetLink.H2" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.BetLink.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.BetLink.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.BetLink.SplashWordmark" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="Widget.BetLink.Chip.Text" parent="TextAppearance.BetLink.Body">
        <item name="android:textColor">@color/brand_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>